{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Normalized Research Evidence",
  "type": "object",
  "required": [
    "evidence_id",
    "scenario_id",
    "channel",
    "record_type",
    "source_url",
    "quote",
    "signal_strength",
    "confidence",
    "evidence_level",
    "evidence_role",
    "source_quality",
    "primary_platform",
    "platform_confidence",
    "platform_confidence_score",
    "platform_reason",
    "secondary_platforms"
  ],
  "properties": {
    "evidence_id": { "type": "string" },
    "scenario_id": { "type": "string" },
    "channel": { "type": "string" },
    "record_type": { "enum": ["post", "question", "answer", "article", "comment", "reply", "review", "metric", "competitor", "unknown"] },
    "source_id": { "type": "string" },
    "parent_source_id": { "type": "string" },
    "comment_id": { "type": "string" },
    "source_url": { "type": "string" },
    "captured_at": { "type": "string" },
    "query": { "type": "string" },
    "title": { "type": "string" },
    "quote": { "type": "string" },
    "comment_signal": { "type": "string" },
    "comments_count": { "type": "integer" },
    "metrics": { "type": "object" },
    "pain_dimension": { "type": "string" },
    "persona": { "type": "string" },
    "signal_strength": { "type": "string" },
    "confidence": { "enum": ["A", "B", "C", "N"] },
    "evidence_level": { "enum": ["A", "B", "C", "N"] },
    "evidence_role": { "enum": ["support", "counter", "noise", "competitor", "gap"] },
    "validation_targets": { "type": "array", "items": { "type": "string" } },
    "source_quality": { "enum": ["full_text", "comment", "title_only", "search_snippet", "metric_only", "unknown"] },
    "interpretation": { "type": "string" },
    "next_step": { "type": "string" },
    "noise": { "type": "boolean" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "primary_platform": { "type": "string" },
    "platform_confidence": { "enum": ["explicit", "inferred_high", "unknown"] },
    "platform_confidence_score": { "type": "integer" },
    "platform_reason": { "type": "string" },
    "secondary_platforms": { "type": "array", "items": { "type": "string" } },
    "raw_run_id": { "type": "string" }
  }
}
