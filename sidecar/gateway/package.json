{
  "name": "llmtoolforge-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LLMToolForge unified gateway sidecar: vendored Portkey gateway (v1.15.2) wrapped with local-key auth, model routing, an Anthropic<->OpenAI bridge and call logging.",
  "scripts": {
    "postinstall": "patch-package --patch-dir portkey/patches",
    "dev": "bun run wrapper/gateway.ts",
    "compile": "bun run build.ts"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@cfworker/json-schema": "^4.0.3",
    "@hono/node-server": "^1.3.3",
    "@hono/node-ws": "^1.2.0",
    "@portkey-ai/mustache": "^2.1.3",
    "@smithy/signature-v4": "^2.1.1",
    "@types/mustache": "^4.2.5",
    "async-retry": "^1.3.3",
    "avsc": "^5.7.7",
    "hono": "^4.9.7",
    "ioredis": "^5.8.0",
    "jose": "^6.0.11",
    "patch-package": "^8.0.1",
    "ws": "^8.18.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/async-retry": "1.4.5",
    "@types/node": "^20.8.3",
    "@types/ws": "^8.5.12"
  }
}
