{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://open.volcengineapi.com/*" },
        { "url": "https://*.volces.com/*" },
        { "url": "https://*.volcengineapi.com/*" }
      ]
    }
  ]
}
