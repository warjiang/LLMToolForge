{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "store:default",
    "window-state:default",
    "sql:allow-load",
    "sql:allow-select",
    "sql:allow-execute",
    "sql:allow-close",
    "updater:default",
    "process:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://open.volcengineapi.com/*" },
        { "url": "https://*.volces.com/*" },
        { "url": "https://*.volcengineapi.com/*" },
        { "url": "http://*/*" },
        { "url": "https://*/*" },
        { "url": "http://*:*/*" },
        { "url": "https://*:*/*" }
      ]
    }
  ]
}
