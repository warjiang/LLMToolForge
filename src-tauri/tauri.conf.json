{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LLMToolForge",
  "version": "0.1.0",
  "identifier": "com.llmtoolforge.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 19, "y": 24 },
        "dragDropEnabled": false,
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:llmtoolforge.db"]
    },
    "updater": {
      "endpoints": [
        "https://github.com/warjiang/LLMToolForge/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDOTdGQ0E3RkM4RDQ1M0QKUldROVJZMzhwL3lYdk11Vzg1dGp0TURaNExJbnRVR0pIY2dRbEpSN3FmVVFNV204UTlGdmRSNHQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/portkey-gateway", "binaries/open-connector"],
    "resources": {
      "resources/connector": "resources/connector"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
